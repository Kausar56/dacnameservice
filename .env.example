# ----------------------------------------------------------------------------
# Database (PostgreSQL) — used by Prisma
# ----------------------------------------------------------------------------
# Pooled connection for the running app (e.g. PgBouncer / Prisma Accelerate).
# Add `?pgbouncer=true&connection_limit=1` when using a transaction pooler.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dacns?schema=public"

# Direct (non-pooled) connection — required by `prisma migrate` & introspection.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/dacns?schema=public"

# Copy this file to `.env` and fill in real credentials.
# Never commit `.env`. Use a least-privilege DB role for the app.
